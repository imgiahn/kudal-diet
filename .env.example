# docker-compose가 자동으로 읽는 루트 .env
# cp .env.example .env 후 값 채우기

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=kudal_db
POSTGRES_USER=kudal
POSTGRES_PASSWORD=your_password_here

# ── JWT (api/.env에도 추가 필요) ─────────────────────────────
# openssl rand -hex 32 로 생성
JWT_SECRET=your_jwt_secret_here
