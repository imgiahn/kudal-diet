# ── 앱 설정 ────────────────────────────────────────────────
APP_NAME=kudal-api
DEBUG=false

# ── 데이터베이스 ────────────────────────────────────────────
# Docker Compose 사용 시: host = postgres (서비스명)
# 로컬 직접 실행 시:      host = localhost
DATABASE_URL=postgresql+asyncpg://kudal:kudal_pw@postgres:5432/kudal_db

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ── 보안 ───────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-very-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Cloudflare R2 ──────────────────────────────────────────
# Cloudflare 대시보드 → R2 → 버킷 → API 토큰에서 발급
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=kudal-prod-images
# 버킷 공개 접근 URL (R2 Public URL 또는 커스텀 도메인)
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# ── Azure OpenAI ────────────────────────────────────────────
# Azure Portal → Cognitive Services → 리소스 → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<resource-name>.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-02-01
